# MongoDB Atlas connection string
# Replace <username>, <password>, and <cluster> with your Atlas credentials
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/expense-tracker?retryWrites=true&w=majority

# Server port (Render sets PORT automatically in production)
PORT=5000

# Allowed frontend origin for CORS (comma-separated for multiple)
# Local: http://localhost:5173,http://localhost:5174
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173,http://localhost:5174
